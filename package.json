  "scripts": {
    "storybook": "node apps/storybook-launcher/index.mjs",
    "js:solution": "node apps/js-fundamentals/scripts/solution.js",
    "js:play": "node apps/js-fundamentals/scripts/solution.js --interactive",
    "js:sync-solutions": "node apps/js-fundamentals/scripts/generate-solution-json.js",
    "ts:qcm": "node apps/ts-fundamentals/scripts/qcm.js",
    "ts:play": "node apps/ts-fundamentals/scripts/qcm.js --interactive",
    "ts:code": "npx jest --config apps/ts-fundamentals/jest.config.js --runInBand",
    "ts:code:play": "node apps/ts-fundamentals/scripts/solution.js",
    "ts:code:watch": "npx jest --config apps/ts-fundamentals/jest.config.js --runInBand --watch",
    "generate": "node scripts/generate/index.js",
    "generate:test": "node scripts/generate/test.js",
    "docs": "typedoc",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md}\"",
    "lint": "nx run-many --target=lint --all",
    "lint:fix": "nx run-many --target=lint --all -- --fix",
    "test": "node scripts/test/nx-test-all.js",
    "affected:lint": "nx affected --target=lint --uncommitted",
    "affected:lint:fix": "nx affected --target=lint --uncommitted -- --fix",
    "affected:typecheck": "nx affected --target=typecheck --uncommitted",
    "affected:test": "node scripts/test/nx-affected.js test origin/dev",
    "affected:ci": "node scripts/test/nx-affected.js lint,test,typecheck origin/main",
    "push": "npm run docs && git push",
    "prepare": "husky"
  },
  "private": true,
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,md}": "prettier --write"
  },
