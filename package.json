{
  "name": "@mas-repo/source",
  "version": "0.0.0",
  "license": "MIT",
  "scripts": {
    "storybook": "node apps/storybook-launcher/index.mjs",
    "generate": "node scripts/generate/index.js",
    "generate:test": "node scripts/generate/test.js",
    "docs": "typedoc",
    "format": "prettier --write \"**/*.{ts,tsx,js,mjs,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,mjs,json,md}\"",
    "lint": "nx run-many --target=lint --all",
    "lint:fix": "nx run-many --target=lint --all -- --fix",
    "test": "nx run-many --target=test --all",
    "affected:lint": "nx affected --target=lint --uncommitted",
    "affected:typecheck": "nx affected --target=typecheck --uncommitted",
    "affected:test": "nx affected --target=test --base=origin/dev",
    "affected:ci": "nx affected --target=lint,test,typecheck --base=origin/main",
    "push": "npm run docs && git push",
    "prepare": "husky"
  },
  "private": true,
  "lint-staged": {
    "*.{ts,tsx,js,mjs,cjs,json,md}": "prettier --write"
  },
  "dependencies": {
    "@expo/metro-config": "~54.0.9",
    "@expo/metro-runtime": "~6.1.2",
    "expo": "~54.0.33",
    "expo-splash-screen": "~31.0.11",
    "expo-status-bar": "~3.0.9",
    "expo-system-ui": "~6.0.9",
    "prompts": "^2.4.2",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-svg": "15.12.1",
    "react-native-svg-transformer": "~1.5.1",
    "react-native-web": "~0.21.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.8.0",
    "@expo/cli": "~54.0.16",
    "@nx/eslint": "22.5.4",
    "@nx/eslint-plugin": "22.5.4",
    "@nx/expo": "22.5.4",
    "@nx/jest": "22.5.4",
    "@nx/js": "22.5.4",
    "@nx/web": "22.5.4",
    "@nx/workspace": "22.5.4",
    "@swc-node/register": "~1.11.1",
    "@swc/core": "~1.15.5",
    "@swc/helpers": "~0.5.18",
    "@testing-library/react-native": "~13.2.0",
    "@types/jest": "^29.5.14",
    "@types/node": "20.19.9",
    "@types/react": "^19.1.0",
    "@typescript-eslint/utils": "^8.40.0",
    "babel-jest": "^29.7.0",
    "babel-plugin-module-resolver": "^5.0.2",
    "babel-preset-expo": "~54.0.7",
    "chalk": "^4.1.2",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "eslint-plugin-import": "2.31.0",
    "eslint-plugin-jsx-a11y": "6.10.1",
    "eslint-plugin-react": "7.35.0",
    "eslint-plugin-react-hooks": "5.0.0",
    "husky": "^9.1.7",
    "jest": "~29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "jest-expo": "~54.0.17",
    "jest-util": "^29.7.0",
    "lint-staged": "^16.3.3",
    "metro-config": "~0.83.0",
    "metro-resolver": "~0.83.0",
    "nx": "22.5.4",
    "prettier": "~3.6.2",
    "react-refresh": "^0.18.0",
    "react-test-renderer": "19.1.0",
    "ts-jest": "^29.2.0",
    "ts-node": "10.9.1",
    "tslib": "^2.3.0",
    "typedoc": "^0.28.17",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0"
  },
  "workspaces": [
    "apps/*",
    "libs/*",
    "libs/**/*"
  ]
}
