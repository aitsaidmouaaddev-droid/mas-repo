{
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "name": "ts-fundamentals",
  "sourceRoot": "apps/ts-fundamentals/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nx/esbuild:esbuild",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "production",
      "options": {
        "platform": "node",
        "outputPath": "apps/ts-fundamentals/dist",
        "format": ["cjs"],
        "bundle": false,
        "main": "apps/ts-fundamentals/src/main.ts",
        "tsConfig": "apps/ts-fundamentals/tsconfig.app.json",
        "assets": ["apps/ts-fundamentals/src/assets"],
        "esbuildOptions": {
          "sourcemap": true,
          "outExtension": {
            ".js": ".js"
          }
        }
      },
      "configurations": {
        "development": {},
        "production": {
          "esbuildOptions": {
            "sourcemap": false,
            "outExtension": {
              ".js": ".js"
            }
          }
        }
      }
    },
    "prune-lockfile": {
      "dependsOn": ["build"],
      "cache": true,
      "executor": "@nx/js:prune-lockfile",
      "outputs": [
        "{workspaceRoot}/apps/ts-fundamentals/dist/package.json",
        "{workspaceRoot}/apps/ts-fundamentals/dist/package-lock.json"
      ],
      "options": {
        "buildTarget": "build"
      }
    },
    "copy-workspace-modules": {
      "dependsOn": ["build"],
      "cache": true,
      "outputs": ["{workspaceRoot}/apps/ts-fundamentals/dist/workspace_modules"],
      "executor": "@nx/js:copy-workspace-modules",
      "options": {
        "buildTarget": "build"
      }
    },
    "prune": {
      "dependsOn": ["prune-lockfile", "copy-workspace-modules"],
      "executor": "nx:noop"
    },
    "serve": {
      "continuous": true,
      "executor": "@nx/js:node",
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "ts-fundamentals:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "ts-fundamentals:build:development"
        },
        "production": {
          "buildTarget": "ts-fundamentals:build:production"
        }
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node node_modules/jest-cli/bin/jest.js --config apps/ts-fundamentals/jest.config.js --runInBand",
        "cwd": "."
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*.ts",
        "{projectRoot}/jest.config.js",
        "{workspaceRoot}/tsconfig.base.json"
      ]
    },
    "qcm": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node apps/ts-fundamentals/scripts/qcm.js --interactive",
        "forwardAllArgs": true,
        "tty": true
      }
    },
    "qcm:review": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node apps/ts-fundamentals/scripts/qcm.js",
        "forwardAllArgs": true
      }
    },
    "qcm:interactive": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node apps/ts-fundamentals/scripts/qcm.js --interactive",
        "tty": true
      }
    },
    "code": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node node_modules/jest-cli/bin/jest.js --config apps/ts-fundamentals/jest.config.js --runInBand",
        "cwd": "."
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/coding/**/*.ts",
        "{projectRoot}/jest.config.js",
        "{workspaceRoot}/tsconfig.base.json"
      ]
    },
    "code:watch": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node node_modules/jest-cli/bin/jest.js --config apps/ts-fundamentals/jest.config.js --watch",
        "cwd": ".",
        "tty": true
      }
    }
  }
}
