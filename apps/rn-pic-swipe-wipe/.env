# --- MEDIA SETTINGS ---
EXPO_PUBLIC_MEDIA_LIMIT=500
EXPO_PUBLIC_BATCH_SIZE=50

# --- DECK PHYSICS ---
EXPO_PUBLIC_SWIPE_THRESHOLD=0.3
EXPO_PUBLIC_ANIM_DURATION=250
EXPO_PUBLIC_OVERLAY_OPACITY=0.75
EXPO_PUBLIC_BACK_SCALE=0.985
EXPO_PUBLIC_SPRING_FRICTION=7

# --- VIDEO PLAYER ---
EXPO_PUBLIC_VIDEO_INTERVAL=0.1
EXPO_PUBLIC_VIDEO_LOOP=true

# --- DECISION COLORS ---
EXPO_PUBLIC_COLOR_TRASH=#FF3B30
EXPO_PUBLIC_COLOR_KEEP=#34C759
EXPO_PUBLIC_COLOR_RESTORE=#007AFF

# --- TABS NAVIGATION ---
EXPO_PUBLIC_TAB_HEIGHT=65
EXPO_PUBLIC_TAB_ACTIVE_COLOR=#FF3B30
EXPO_PUBLIC_TAB_INACTIVE_COLOR=#8E8E93