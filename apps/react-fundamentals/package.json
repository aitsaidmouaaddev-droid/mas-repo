{
  "name": "@mas-repo/react-fundamentals",
  "version": "1.1.2",
  "private": true,
  "scripts": {
    "serve:api": "node scripts/server.js",
    "serve:app": "vite serve",
    "dev": "concurrently \"npm run serve:api\" \"npm run serve:app\"",
    "db:generate": "node ../../tools/scripts/generate-migration.mjs",
    "db:run": "node ../../tools/typeorm-cli.js migration:run -d datasource.ts",
    "db:revert": "node ../../tools/typeorm-cli.js migration:revert -d datasource.ts",
    "db:show": "node ../../tools/typeorm-cli.js migration:show -d datasource.ts",
    "codegen": "graphql-codegen --config graphql/codegen.ts"
  },
  "dependencies": {
    "pg": "^8.20.0"
  }
}
