{
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node node_modules/jest-cli/bin/jest.js --config apps/test-deploy/jest.config.js --runInBand",
        "cwd": "."
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*.ts",
        "{projectRoot}/jest.config.js",
        "{workspaceRoot}/tsconfig.base.json"
      ]
    }
  }
}
