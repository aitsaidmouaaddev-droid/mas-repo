{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "dist",
    "module": "nodenext",
    "types": ["node"],
    "rootDir": "src",
    "moduleResolution": "nodenext",
    "allowJs": true,
    "checkJs": false,
    "tsBuildInfoFile": "dist/tsconfig.app.tsbuildinfo"
  },
  "include": ["src/main.js"],
  "exclude": [
    "out-tsc",
    "dist",
    "src/**/*.spec.js",
    "src/**/*.test.js",
    "src/01-*/**",
    "src/02-*/**",
    "src/03-*/**",
    "src/04-*/**",
    "src/05-*/**",
    "src/06-*/**",
    "src/07-*/**",
    "src/08-*/**",
    "src/09-*/**",
    "src/10-*/**",
    "eslint.config.js",
    "eslint.config.cjs",
    "eslint.config.mjs"
  ]
}
