# ─── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ─── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4444
JWT_SECRET=change-me-in-production

# ─── IP Allowlist (optional) ─────────────────────────────────────────────────
# Loopback is always permitted. Add your public IP for production.
# Find yours at: https://api.ipify.org
# ALLOWED_IPS=1.2.3.4

# ─── Gmail API (OAuth2) ───────────────────────────────────────────────────────
# Used for sending trigger/review/notification emails + polling inbound replies.
# Set up at: https://console.cloud.google.com → APIs & Services → Credentials
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=GOCSPX-your-client-secret
GMAIL_REFRESH_TOKEN=your-gmail-refresh-token
GMAIL_USER_EMAIL=your-sender@gmail.com

# ─── Notification destination ────────────────────────────────────────────────
# The address that receives trigger/review/upload emails and sends replies.
NOTIFICATION_EMAIL=your-notification@gmail.com

# ─── YouTube Data API v3 (OAuth2) ────────────────────────────────────────────
# Separate refresh token scoped to YouTube upload.
# Obtain via: node tools/scripts/get-youtube-token.mjs
YOUTUBE_REFRESH_TOKEN=your-youtube-refresh-token

# ─── Anthropic Claude API ────────────────────────────────────────────────────
# Get your key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-api03-your-key

# ─── Google Cloud Text-to-Speech ─────────────────────────────────────────────
# Paste the full minified JSON from your service account key file.
# Create a service account at: https://console.cloud.google.com → IAM → Service Accounts
GOOGLE_TTS_KEY_JSON={"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}

# ─── fal.ai (Wan 2.1 video generation) ───────────────────────────────────────
# Get your key at: https://fal.ai → Settings → API Keys
FAL_API_KEY=your-fal-api-key
