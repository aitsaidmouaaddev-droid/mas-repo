{
  "name": "mas-videos-generator",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "projectType": "application",
  "tags": ["scope:backend", "type:app"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/apps/mas-videos-generator/dist"],
      "defaultConfiguration": "production",
      "options": {
        "command": "webpack-cli build --node-env=production",
        "cwd": "apps/mas-videos-generator"
      },
      "configurations": {
        "development": {
          "command": "webpack-cli build --node-env=development"
        },
        "production": {
          "command": "webpack-cli build --node-env=production"
        }
      }
    },

    "serve": {
      "executor": "@nx/js:node",
      "continuous": true,
      "defaultConfiguration": "development",
      "dependsOn": ["build"],
      "options": {
        "buildTarget": "mas-videos-generator:build",
        "runBuildTargetDependencies": false
      },
      "configurations": {
        "development": {
          "buildTarget": "mas-videos-generator:build:development"
        },
        "production": {
          "buildTarget": "mas-videos-generator:build:production"
        }
      }
    },

    "serve:dev": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "command": "npx ts-node -r tsconfig-paths/register --project tsconfig.server.json src/main.ts",
        "cwd": "apps/mas-videos-generator"
      }
    },

    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p tsconfig.app.json",
        "cwd": "apps/mas-videos-generator"
      }
    },

    "lint": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint .",
        "cwd": "apps/mas-videos-generator"
      }
    },

    "lint-fix": {
      "executor": "nx:run-commands",
      "options": {
        "command": "eslint --fix .",
        "cwd": "apps/mas-videos-generator"
      }
    },

    "format": {
      "executor": "nx:run-commands",
      "options": {
        "command": "prettier --write \"src/**/*.{ts,tsx,json}\"",
        "cwd": "apps/mas-videos-generator"
      }
    },

    "fix": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "npx nx run mas-videos-generator:lint-fix",
          "npx nx run mas-videos-generator:format"
        ],
        "parallel": false
      }
    },

    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/apps/mas-videos-generator/test-output/jest/coverage"],
      "options": {
        "command": "node ../../node_modules/jest/bin/jest.js --config jest.config.ts --passWithNoTests",
        "cwd": "apps/mas-videos-generator"
      },
      "configurations": {
        "ci": {
          "command": "node ../../node_modules/jest/bin/jest.js --config jest.config.ts --passWithNoTests --ci --runInBand"
        }
      }
    },

    "test:watch": {
      "executor": "nx:run-commands",
      "continuous": true,
      "options": {
        "command": "node ../../node_modules/jest/bin/jest.js --config jest.config.ts --watch",
        "cwd": "apps/mas-videos-generator"
      }
    },

    "db:generate": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node ../../tools/scripts/generate-migration.mjs",
        "cwd": "apps/mas-videos-generator"
      }
    },

    "db:run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node ../../tools/typeorm-cli.js migration:run -d datasource.ts",
        "cwd": "apps/mas-videos-generator"
      }
    },

    "db:revert": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node ../../tools/typeorm-cli.js migration:revert -d datasource.ts",
        "cwd": "apps/mas-videos-generator"
      }
    },

    "db:show": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node ../../tools/typeorm-cli.js migration:show -d datasource.ts",
        "cwd": "apps/mas-videos-generator"
      }
    },

    "prune-lockfile": {
      "executor": "@nx/js:prune-lockfile",
      "dependsOn": ["build"],
      "cache": true,
      "outputs": [
        "{workspaceRoot}/apps/mas-videos-generator/dist/package.json",
        "{workspaceRoot}/apps/mas-videos-generator/dist/package-lock.json"
      ],
      "options": {
        "buildTarget": "mas-videos-generator:build"
      }
    },

    "copy-workspace-modules": {
      "executor": "@nx/js:copy-workspace-modules",
      "dependsOn": ["build"],
      "cache": true,
      "outputs": ["{workspaceRoot}/apps/mas-videos-generator/dist/workspace_modules"],
      "options": {
        "buildTarget": "mas-videos-generator:build"
      }
    },

    "prune": {
      "executor": "nx:noop",
      "dependsOn": ["prune-lockfile", "copy-workspace-modules"]
    }
  }
}
