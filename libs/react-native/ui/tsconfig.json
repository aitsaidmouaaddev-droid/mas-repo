{
  "extends": "../../../tsconfig.base.json",
  "compilerOptions": {
    "composite": false,
    "declaration": false,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "noEmit": true,
    "noUnusedLocals": false,
    "jsx": "react-jsx",
    "paths": {
      "@mas/shared/types": ["../../shared/types/src/index.ts"],
