{
  "name": "@mas/rn-media",
  "tags": ["scope:rn", "type:lib"],
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node node_modules/jest-cli/bin/jest.js --config libs/react-native/media/jest.config.cts --runInBand",
        "cwd": "."
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*.ts",
        "{projectRoot}/jest.config.cts",
        "{workspaceRoot}/tsconfig.base.json"
      ]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p tsconfig.json",
        "cwd": "libs/react-native/media"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/tsconfig.json",
        "{projectRoot}/src/**/*.ts",
        "{projectRoot}/src/**/*.tsx",
        "{workspaceRoot}/tsconfig.base.json"
      ]
    }
  }
}
