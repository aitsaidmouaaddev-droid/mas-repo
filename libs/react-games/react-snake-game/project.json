{
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "name": "react-snake-game",
  "sourceRoot": "libs/react-games/react-snake-game/src",
  "projectType": "library",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p libs/react-games/react-snake-game/tsconfig.lib.json",
        "cwd": "."
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*.ts",
        "{projectRoot}/src/**/*.tsx",
        "{projectRoot}/tsconfig.lib.json",
        "{workspaceRoot}/tsconfig.base.json"
      ]
    }
  }
}
