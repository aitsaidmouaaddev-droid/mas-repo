{
  "name": "@mas/mas-sqlite",
  "tags": ["scope:shared", "type:lib"],
  "targets": {
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node node_modules/jest-cli/bin/jest.js --config libs/shared/mas-sqlite/jest.config.js --runInBand",
        "cwd": "."
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*.ts",
        "{projectRoot}/jest.config.js",
        "{workspaceRoot}/tsconfig.base.json"
      ]
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p tsconfig.json",
        "cwd": "libs/shared/mas-sqlite"
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/tsconfig.json",
        "{projectRoot}/src/**/*.ts",
        "{projectRoot}/src/**/*.tsx",
        "{workspaceRoot}/tsconfig.base.json"
      ]
    }
  }
}
