{
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "name": "db-contracts",
  "sourceRoot": "libs/nest/db-contracts/src",
  "projectType": "library",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p libs/nest/db-contracts/tsconfig.lib.json",
        "cwd": "."
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*.ts",
        "{projectRoot}/tsconfig.lib.json",
        "{workspaceRoot}/tsconfig.base.json"
      ]
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node node_modules/jest-cli/bin/jest.js --config libs/nest/db-contracts/jest.config.js --runInBand",
        "cwd": "."
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*.ts",
        "{projectRoot}/jest.config.js",
        "{workspaceRoot}/tsconfig.base.json"
      ]
    }
  }
}
