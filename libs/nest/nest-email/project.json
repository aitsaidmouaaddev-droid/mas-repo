{
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "name": "nest-email",
  "sourceRoot": "libs/nest/nest-email/src",
  "projectType": "library",
  "targets": {
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc --noEmit -p libs/nest/nest-email/tsconfig.lib.json",
        "cwd": "."
      },
      "cache": true,
      "inputs": [
        "{projectRoot}/src/**/*.ts",
        "{projectRoot}/tsconfig.lib.json",
        "{workspaceRoot}/tsconfig.base.json"
      ]
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/nest/nest-email/**/*.ts"]
      },
      "cache": true
    }
  }
}
