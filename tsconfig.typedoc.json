{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "noUnusedLocals": false,
    "paths": {
      "@mas/rn/ui": ["libs/react-native/ui/src/index.ts"],
      "@mas/rn/ui/*": ["libs/react-native/ui/src/*"],
      "@mas/shared/store": ["libs/shared/store/src/index.ts"],
      "@mas/rn/database": ["libs/react-native/database/src/index.ts"],
      "@mas/rn/media": ["libs/react-native/media/src/index.ts"],
      "@mas/shared/types": ["libs/shared/types/src/index.ts"],
      "@mas/shared/types/*": ["libs/shared/types/src/*"],
      "@mas/frontend-dal": ["libs/shared/frontend-dal/src/index.ts"],
      "@mas/mas-sqlite": ["libs/shared/mas-sqlite/src/index.ts"],
      "@mas/qcm": ["libs/shared/qcm/src/index.ts"],
      "@mas/shared/theme": ["libs/shared/theme/src/index.ts"],
      "@mocks/*": ["apps/rn-pic-swipe-wipe/mocks/*"],
      "@styles/*": ["apps/rn-pic-swipe-wipe/styles/*"],
      "@components/*": ["apps/rn-pic-swipe-wipe/app/components/*"],
      "@/*": ["apps/rn-pic-swipe-wipe/*"],
      "@mas/react/ui": ["libs/react/ui/src/index.ts"],
      "@mas/react/router": ["libs/react/router/src/index.ts"],
      "@mas/db-contracts": ["libs/nest/db-contracts/src/index.ts"],
      "@mas/nest/nest-graphql-typeorm-base": ["libs/nest/nest-graphql-typeorm-base/src/index.ts"],
      "@mas/nest/auth": ["libs/nest/auth/src/index.ts"]
    }
  },
  "include": [
    "libs/react-native/ui/src/**/*.ts",
    "libs/react-native/ui/src/**/*.tsx",
    "libs/react-native/database/src/**/*.ts",
    "libs/react-native/database/src/**/*.tsx",
    "libs/react-native/media/src/**/*.ts",
    "libs/react-native/media/src/**/*.tsx",
    "libs/shared/store/src/**/*.ts",
    "libs/shared/types/src/**/*.ts",
    "libs/shared/frontend-dal/src/**/*.ts",
    "libs/shared/mas-sqlite/src/**/*.ts",
    "apps/rn-pic-swipe-wipe/app/**/*.ts",
    "apps/rn-pic-swipe-wipe/app/**/*.tsx",
    "apps/rn-pic-swipe-wipe/store/**/*.ts",
    "apps/rn-pic-swipe-wipe/hooks/**/*.ts",
    "apps/rn-pic-swipe-wipe/services/**/*.ts",
    "apps/rn-pic-swipe-wipe/db/**/*.ts",
    "apps/rn-pic-swipe-wipe/styles/**/*.ts",
    "apps/rn-pic-swipe-wipe/types/**/*.ts",
    "apps/storybook-native/**/*.ts",
    "apps/storybook-native/**/*.tsx",
    "libs/shared/qcm/src/**/*.ts",
    "apps/js-fundamentals/src/**/*.js",
    "apps/ts-fundamentals/src/**/*.ts",
    "apps/react-fundamentals/src/**/*.ts",
    "apps/react-fundamentals/src/**/*.tsx",
    "apps/storybook-launcher/**/*.mjs",
    "apps/storybook-launcher/**/*.js",
    "libs/shared/theme/src/**/*.ts",
    "libs/react/ui/src/**/*.ts",
    "libs/react/ui/src/**/*.tsx",
    "libs/react/ui/src/**/*.js",
    "libs/react/ui/src/**/*.mjs",
    "libs/react/router/src/**/*.ts",
    "libs/react/router/src/**/*.tsx",
    "libs/react/router/src/**/*.js",
    "libs/react/router/src/**/*.mjs",
    "libs/nest/db-contracts/src/**/*.ts",
    "libs/nest/db-contracts/src/**/*.tsx",
    "libs/nest/db-contracts/src/**/*.js",
    "libs/nest/db-contracts/src/**/*.mjs",
    "libs/nest/nest-graphql-typeorm-base/src/**/*.ts",
    "libs/nest/nest-graphql-typeorm-base/src/**/*.tsx",
    "libs/nest/nest-graphql-typeorm-base/src/**/*.js",
    "libs/nest/nest-graphql-typeorm-base/src/**/*.mjs",
    "libs/nest/auth/src/**/*.ts",
    "libs/nest/auth/src/**/*.tsx",
    "libs/nest/auth/src/**/*.js",
    "libs/nest/auth/src/**/*.mjs"
  ],
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.stories.ts",
    "**/*.stories.tsx",
    "**/node_modules/**",
    "**/.expo/**",
    "**/dist/**",
    "**/out-tsc/**"
  ]
}
