{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "jsx": "react-jsx",
    "noUnusedLocals": false
  },
  "include": [
    "libs/react-native/ui/src/index.ts",
    "libs/react-native/ui/src/**/*.ts",
    "libs/react-native/ui/src/**/*.tsx",
    "libs/react-native/database/src/index.ts",
    "libs/react-native/database/src/**/*.ts",
    "libs/react-native/database/src/**/*.tsx",
    "libs/react-native/media/src/index.ts",
    "libs/react-native/media/src/**/*.ts",
    "libs/react-native/media/src/**/*.tsx",
    "libs/shared/store/src/index.ts",
    "libs/shared/store/src/**/*.ts",
    "libs/shared/types/src/index.ts",
    "libs/shared/types/src/**/*.ts",
    "libs/shared/frontend-dal/src/index.ts",
    "libs/shared/frontend-dal/src/**/*.ts",
    "libs/shared/mas-sqlite/src/index.ts",
    "libs/shared/mas-sqlite/src/**/*.ts"
  ],
  "exclude": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/*.stories.ts",
    "**/*.stories.tsx",
    "node_modules"
  ]
}
