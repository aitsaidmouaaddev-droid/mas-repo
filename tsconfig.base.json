{
  "compilerOptions": {
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "customConditions": ["@mas-repo/source"],
    "paths": {
      "@mas/rn/ui": ["libs/react-native/ui/src/index.ts"],
      "@mas/rn/ui/*": ["libs/react-native/ui/src/*"],
      "@mas/rn/store": ["libs/react-native/store/src/index.ts"],
      "@mas/rn/database": ["libs/react-native/database/src/index.ts"],
      "@mas/rn/services": ["libs/react-native/services/src/index.ts"],
      "@mas/rn/hooks": ["libs/react-native/hooks/src/index.ts"],
      "@mas/shared/types": ["libs/shared/types/src/index.ts"],
      "@mas/shared/config": ["libs/shared/config/src/index.ts"],
      "@mas/react-shared": ["libs/react/react-shared/src/index.ts"],
      "@mas/frontend-dal": ["libs/shared/frontend-dal/src/index.ts"],
      "@mas/mas-sqlite": ["libs/shared/mas-sqlite/src/index.ts"]
    }
  }
}
