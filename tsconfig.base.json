{
  "compilerOptions": {
    "baseUrl": ".",
    "composite": true,
    "declarationMap": true,
    "emitDeclarationOnly": true,
    "importHelpers": true,
    "isolatedModules": true,
    "lib": ["es2022"],
    "module": "esnext",
    "moduleResolution": "bundler",
    "noEmitOnError": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitOverride": true,
    "noImplicitReturns": true,
    "noUnusedLocals": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2022",
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "customConditions": ["@mas-repo/source"],
    "paths": {
      "@mas/rn/ui": ["libs/react-native/ui/src/index.ts"],
      "@mas/rn/ui/*": ["libs/react-native/ui/src/*"],
      "@mas/shared/store": ["libs/shared/store/src/index.ts"],
      "@mas/shared/qcm": ["libs/shared/qcm/src/index.ts"],
      "@mas/rn/database": ["libs/react-native/database/src/index.ts"],
      "@mas/rn/media": ["libs/react-native/media/src/index.ts"],
      "@mas/shared/types": ["libs/shared/types/src/index.ts"],
      "@mas/frontend-dal": ["libs/shared/frontend-dal/src/index.ts"],
      "@mas/mas-sqlite": ["libs/shared/mas-sqlite/src/index.ts"],
      "@mas/shared/theme": ["libs/shared/theme/src/index.ts"],
      "@mas/shared/i18n": ["libs/shared/i18n/src/index.ts"],
      "@mas/react-ui": ["libs/react/ui/src/index.ts"],
      "@mas/react-router": ["libs/react/router/src/index.ts"],
      "@mas/nest-graphql-typeorm-base": ["libs/nest/nest-graphql-typeorm-base/src/index.ts"],
      "@mas/db-contracts": ["libs/nest/db-contracts/src/index.ts"],
      "@mas/db-typeorm": ["libs/nest/db-typeorm/src/index.ts"],
      "@mas/auth": ["libs/nest/auth/src/index.ts"],
      "@mas/react-fundamentals-sot": ["libs/react-fundamentals/sot/src/index.ts"],
      "@mas/front-auth": ["libs/react/front-auth/src/index.ts"],
      "@mas/nest-games": ["libs/nest/games/src/index.ts"],
      "@mas/react-snake-game": ["libs/react-games/react-snake-game/src/index.ts"]
    }
  }
}
