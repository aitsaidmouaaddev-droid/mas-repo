#!/usr/bin/env bash

# CI=true forces Nx into static (non-interactive) output mode.
# Without this, Nx opens an interactive viewer in a real terminal that
# requires pressing `q` to exit — blocking the push flow.
export CI=true

# ── Affected tests ─────────────────────────────────────────────────────────────
npm run affected:test

# ── Interactive version bump (only when pushing to dev) ────────────────────────
while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "$remote_ref" == "refs/heads/dev" ]]; then

    # Only prompt when /dev/tty is actually openable.
    if ! (true < /dev/tty) 2>/dev/null; then
      echo "Skipping version bump (no interactive terminal)."
      continue
    fi

    # Resolve base: new branch → fall back to origin/main.
    if [[ "$remote_sha" == "0000000000000000000000000000000000000000" ]]; then
      base="origin/main"
    else
      base="$remote_sha"
    fi

    # Compute affected project names for this exact push.
    AFFECTED=$(npx nx show projects --affected --base="$base" --head="$local_sha" 2>/dev/null)

    # ── Helper: prompt version bump for a given package.json ─────────────────
    bump_version() {
      local pkg_file="$1"
      local label="$2"

      [[ -f "$pkg_file" ]] || return

      local current_version
      current_version=$(node -p "try { require('./${pkg_file}').version || '' } catch(e) { '' }" 2>/dev/null)
      if [[ -z "$current_version" || "$current_version" == "undefined" ]]; then
        return
      fi

      echo ""
      echo "  ┌─ ${label}  (current: v${current_version})"
      echo "  │  1 = +1.0.0 (major)   2 = +0.1.0 (minor)   3 = +0.0.1 (patch)   s = skip"
      printf "  └> "
      read -r choice < /dev/tty

      local bump_type=""
      case "$choice" in
        1) bump_type="major" ;;
        2) bump_type="minor" ;;
        3) bump_type="patch" ;;
        *) echo "     Skipped." ; return ;;
      esac

      local dir
      dir=$(dirname "$pkg_file")
      (cd "$dir" && npm version "$bump_type" --no-git-tag-version) > /dev/null

      local new_version
      new_version="v$(node -p "require('./${pkg_file}').version")"

      git add "${pkg_file}" package-lock.json
      git commit --no-verify -m "chore(${label}): bump version to ${new_version}"
      git tag "${label}/${new_version}"
      echo "     ✓ Bumped to ${new_version} — tag created locally."
    }

    # ── Apps ─────────────────────────────────────────────────────────────────
    echo ""
    echo "━━━ Version bump — Apps ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    any_app=false
    for pkg_file in apps/*/package.json; do
      [[ -f "$pkg_file" ]] || continue
      app_name=$(basename "$(dirname "$pkg_file")")
      echo "$AFFECTED" | grep -q "$app_name" || continue
      any_app=true
      bump_version "$pkg_file" "$app_name"
    done
    $any_app || echo "  No affected apps."

    # ── Libs ─────────────────────────────────────────────────────────────────
    echo ""
    echo "━━━ Version bump — Libs ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    any_lib=false
    for pkg_file in libs/*/*/package.json libs/*/package.json; do
      [[ -f "$pkg_file" ]] || continue
      lib_name=$(basename "$(dirname "$pkg_file")")
      echo "$AFFECTED" | grep -q "$lib_name" || continue
      any_lib=true
      bump_version "$pkg_file" "$lib_name"
    done
    $any_lib || echo "  No affected libs."

    echo ""

  fi
done

exit 0
