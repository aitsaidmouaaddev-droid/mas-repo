#!/usr/bin/env bash

# CI=true forces Nx into static (non-interactive) output mode.
# Without this, Nx opens an interactive viewer in a real terminal that
# requires pressing `q` to exit — blocking the push flow.
export CI=true

# ── Affected tests ─────────────────────────────────────────────────────────────
# Run tests for every project touched by this diff before the push lands.
npm run affected:test

# ── Interactive version bump (only when pushing to dev) ────────────────────────
# Reads the refs being pushed from git's stdin.
# For each ref, if the destination is dev, offers an interactive version bump
# for every app in apps/* that is affected by this push.
while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
  if [[ "$remote_ref" == "refs/heads/dev" ]]; then

    # Only prompt when /dev/tty is actually openable.
    # On Windows or when git is invoked non-interactively (e.g. via `npm run push`),
    # /dev/tty exists as a path but cannot be opened — test it in a subshell first.
    if ! (true < /dev/tty) 2>/dev/null; then
      echo "Skipping version bump (no interactive terminal)."
      continue
    fi

    # Resolve base: new branch (remote_sha = 000...0) → fall back to origin/main.
    if [[ "$remote_sha" == "0000000000000000000000000000000000000000" ]]; then
      base="origin/main"
    else
      base="$remote_sha"
    fi

    # Compute affected project names for this exact push.
    AFFECTED=$(npx nx show projects --affected --base="$base" --head="$local_sha" 2>/dev/null)

    # Loop over every app that has a package.json with a version field.
    for pkg_file in apps/*/package.json; do
      [[ -f "$pkg_file" ]] || continue
      app_dir=$(dirname "$pkg_file")
      app_name=$(basename "$app_dir")

      # Skip if this app is not in the affected set.
      if ! echo "$AFFECTED" | grep -q "$app_name"; then
        continue
      fi

      # Skip if the package.json has no version field.
      current_version=$(node -p "try { require('./${pkg_file}').version || '' } catch(e) { '' }" 2>/dev/null)
      if [[ -z "$current_version" || "$current_version" == "undefined" ]]; then
        continue
      fi

      echo ""
      echo "Bump ${app_name} version? (current: ${current_version}) [patch | minor | major | skip]"
      printf "> "
      # Read from /dev/tty — git redirects stdin to push data, so we must
      # open the terminal directly to get the user's keystrokes.
      read -r choice < /dev/tty

      case "$choice" in
        patch|minor|major)
          # Run npm version inside the app directory (subshell keeps cwd clean).
          # --no-git-tag-version = don't let npm create the commit/tag — we do it below.
          (cd "$app_dir" && npm version "$choice" --no-git-tag-version) > /dev/null
          NEW_VERSION="v$(node -p "require('./${pkg_file}').version")"
          # Stage both package.json and the root package-lock.json.
          # npm version in a workspace package updates both files.
          git add "${pkg_file}" package-lock.json
          git commit -m "chore(${app_name}): bump version to $NEW_VERSION"
          # Create the tag locally. It won't be pushed to the remote until the
          # CD workflow does it after the dev→main PR is merged.
          git tag "${app_name}/$NEW_VERSION"
          echo "Version bumped to $NEW_VERSION — tag created locally."
          ;;
        *)
          echo "Skipping version bump for ${app_name}."
          ;;
      esac
    done

  fi
done

exit 0
